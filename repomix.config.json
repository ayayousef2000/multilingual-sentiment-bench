{
  "output": {
    "filePath": "multilingual-sentiment-bench-code.xml",
    "style": "xml",
    "compress": true,
    "removeComments": true,
    "removeEmptyLines": true,
    "showLineNumbers": false,
    "copyToClipboard": false,
    "parsableStyle": false,
    "git": {
      "sortByChanges": true,
      "sortByChangesMaxCommits": 100
    }
  },
  "include": ["**/*", "**/*.mjs", ".github/**/*"],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      ".git",
      "node_modules",
      ".venv",
      "__pycache__",
      "*.pyc",
      "dist",
      "build",
      "*.log",
      ".env",
      "package-lock.json",
      ".pnpm-store",
      "pnpm-lock.yaml",
      "multilingual-sentiment-bench-code.xml",
      "repomix.config.json",
      "**/.devcontainer/**",
      "**/.github/**",
      "**/.husky/**",
      "**/docker/**",
      "**/public/**",
      "**/scripts/**",
      "**/assets/**",
      "**/README.md",
      "**/.dockerignore",
      "**/.gitignore"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
