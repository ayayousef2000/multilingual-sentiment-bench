{
  "output": {
    "filePath": "multilingual-sentiment-bench-code.xml",
    "style": "xml",
    "compress": true,
    "removeComments": true,
    "removeEmptyLines": true,
    "showLineNumbers": false,
    "copyToClipboard": false,
    "parsableStyle": true,
    "git": {
      "sortByChanges": true,
      "sortByChangesMaxCommits": 100
    }
  },
  "include": ["src/**/*"],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "repomix.config.json",
      "src/**/*.test.*",
      "src/**/*.spec.*",
      "src/**/*.stories.*",
      "src/**/__tests__/**",
      "src/**/__mocks__/**",
      "**/.devcontainer/**",
      "**/.github/**",
      "**/.husky/**",
      "**/docker/**",
      "**/public/**",
      "**/scripts/**",
      "**/assets/**",
      "**/README.md",
      "**/.dockerignore",
      "**/.gitignore",
      "**/docker-compose.yml"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
