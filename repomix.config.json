{
  "output": {
    "style": "xml",
    "removeComments": true,
    "removeEmptyLines": true,
    "compress": true,
    "filePath": "multilingual-sentiment-bench-code.xml"
  },
  "include": ["**/*", "**/*.mjs", ".github/**/*"],
  "security": {
    "enableSecurityCheck": false
  },
  "ignore": {
    "useGitignore": false,
    "useDefaultPatterns": false,
    "customPatterns": [
      ".git",
      "node_modules",
      ".venv",
      "__pycache__",
      "*.pyc",
      "dist",
      "build",
      "*.log",
      ".env",
      "package-lock.json",
      ".pnpm-store",
      "pnpm-lock.yaml",
      "multilingual-sentiment-bench-code.xml",
      "repomix.config.json"
    ]
  }
}
